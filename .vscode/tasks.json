{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build",
            "command": "${command:stm32-for-vscode.build}",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "type": "shell",
            "label": "Flash",
            "command": "${command:stm32-for-vscode.flash}",
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "Build + Flash",
            "command": "${command:stm32-for-vscode.buildAndFlash}",
            "problemMatcher": "$gcc"
        },
        {
            "type": "shell",
            "label": "Clean",
            "command": "${command:stm32-for-vscode.cleanBuild}",
            "problemMatcher": []
        }
    ]
}
